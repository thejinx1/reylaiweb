{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "reylai-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-06",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "routes": [
    {
      "pattern": "ai.reyliar.xyz/api/*",
      "zone_name": "reyliar.xyz"
    },
    {
      "pattern": "mail.reyliar.xyz",
      "custom_domain": true
    }
  ],
  "vars": {
    "STATIC_ORIGIN": "https://ai.reyliar.xyz/",
    "BOOKS_REMOTE_BASE_URL": "https://reyliar.github.io/blupblupreylai-books/",
    "MEB_SCHOOLS_API_URL": "https://www.meb.gov.tr/baglantilar/okullar/okullar_ajax.php",
    "GEMINI_API_URL": "https://generativelanguage.googleapis.com/v1beta/models",
    "GEMINI_MODEL": "gemini-3.1-pro",
    "GEMINI_FALLBACK_MODELS": "gemini-3.5-flash,gemini-3-flash-preview,gemini-3.1-flash-lite",
    "MISTRAL_API_URL": "https://api.mistral.ai/v1/chat/completions",
    "MISTRAL_MODEL": "mistral-large-latest",
    "AI_FETCH_TIMEOUT_MS": "25000",
    "TURNSTILE_SITE_KEY": "0x4AAAAAADf7TXMs0rMZvUad",
    "AUTH_REQUIRE_TURNSTILE": "true",
    "RESEND_API_URL": "https://api.resend.com",
    "CONTACT_FORWARD_TO": "mynamesreyli@gmail.com",
    "MAIL_PANEL_USER": "reyliar",
    "GITHUB_REPO_OWNER": "reyliar",
    "GITHUB_REPO_NAME": "blupblupreylai-books",
    "GITHUB_API_BRANCH": "main"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "reylai-auth",
      "database_id": "45f3c5b2-9c8a-4b59-a653-f5bd53ec6d7a",
      "migrations_dir": "./migrations"
    }
  ],
  "secrets": {
    "required": ["GEMINI_API_KEY", "MISTRAL_API_KEY", "GAS_WEB_APP_URL", "TURNSTILE_SECRET_KEY", "RESEND_API_KEY", "RESEND_WEBHOOK_SECRET", "MAIL_PANEL_PASSWORD", "GITHUB_TOKEN"]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
